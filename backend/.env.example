# Renomeie este arquivo para .env e configure os valores abaixo
# O arquivo .env nunca deve ser enviado ao GitHub

# Chave secreta para assinar cookies de sessão — use uma string longa e aleatória
# Para gerar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria

# Chave usada para assinar os tokens JWT da API (/api/auth/token).
# Opcional: se não definida, reaproveita a SECRET_KEY acima.
# JWT_SECRET_KEY=troque-por-outra-chave-secreta-longa-e-aleatoria

# Tempo de validade do token JWT, em horas (padrão: 8)
# JWT_EXP_HOURS=8

# ── Oracle Autonomous Database (modo thin do oracledb) ──────────────
# Usuário do schema (normalmente ADMIN no Always Free)
DB_USER=troque-pelo-usuario-do-banco
# Senha do usuário acima — NUNCA commitar o valor real
DB_PASSWORD=troque-pela-senha-do-banco
# Nome do serviço/TNS alias (ex.: meubanco_high, meubanco_medium, meubanco_low)
DB_DSN=troque-pelo-tns-alias-do-servico
# Pasta onde o wallet (cwallet.sso, tnsnames.ora, sqlnet.ora, etc.) foi extraído
DB_WALLET_DIR=/caminho/para/o/wallet
# Senha do wallet (definida na hora do download do wallet no OCI Console)
DB_WALLET_PASSWORD=troque-pela-senha-do-wallet
